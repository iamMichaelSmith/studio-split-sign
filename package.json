{
  "name": "split-sheet-open-sign",
  "version": "0.1.0",
  "private": true,
  "description": "Music studio split-sheet platform with a web app, JSON API, and JUCE VST client",
  "main": "server.js",
  "scripts": {
    "dev": "node --use-system-ca server.js",
    "start": "node --use-system-ca server.js",
    "test": "node tests/smoke.cjs",
    "test:postgres": "node tests/smoke-postgres.cjs",
    "db:postgres:setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-local-postgres.ps1",
    "vst:build": "powershell -ExecutionPolicy Bypass -File .\\vst\\build-and-install.ps1",
    "vst:package": "powershell -ExecutionPolicy Bypass -File .\\vst\\package-installer.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1077.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "nanoid": "^3.3.11",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.17.2",
    "pg": "^8.22.0",
    "serverless-http": "^4.0.0",
    "signature_pad": "^4.1.7"
  }
}
