<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Forgot password | SplitSheet Studio</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wrap auth-wrap">
    <div class="auth-card card">
      <h1>Reset your password</h1>
      <p class="small">Enter the email tied to your SplitSheet Studio account. We will send a reset link if it exists.</p>
      <% if (error) { %>
        <div class="card legal-note"><%= error %></div>
      <% } %>
      <form method="post" action="/forgot-password">
        <label>Email</label>
        <input type="email" name="email" value="<%= value %>" required>
        <button type="submit">Send reset link</button>
      </form>
      <p class="small auth-links">
        <a href="/signup">Create account</a>
        <a href="mailto:<%= supportEmail %>">Support</a>
        <a href="<%= baseUrl %>">Back to app</a>
      </p>
    </div>
  </div>
</body>
</html>
