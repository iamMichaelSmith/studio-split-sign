<!doctype html><html><head><meta charset="utf-8"><title>Sync Collaboration</title><link rel="stylesheet" href="/style.css"></head><body><div class="wrap"><h1>Sync Collaboration Agreement</h1><div class="card"><p>Sync-only collaboration. Blak Marigold Pro LLC owns masters/compositions unless separately amended in writing. No public release. 50/50 net sync split. Texas law.</p></div><form method="post" action="/sync-collab"><div id="collabs"></div><button type="button" id="add">+ Add collaborator</button><div class="card"><label>Company rep name</label><input name="companyRepName" required><label>Signed date</label><input type="date" name="signedDate" required><canvas id="companySig" class="sig"></canvas><input type="hidden" id="companySigData" name="companyRepSignature"><button type="button" id="clearCompany">Clear signature</button></div><button type="submit">Submit agreement</button></form><p><a href="/">Back</a></p></div><script src="/vendor/signature_pad/signature_pad.umd.min.js"></script>
<script>
function wirePad(canvasId,inputId,clearId){const canvas=document.getElementById(canvasId);if(!canvas)return; if(typeof SignaturePad==='undefined'){return;} const resize=()=>{const ratio=Math.max(window.devicePixelRatio||1,1);canvas.width=canvas.offsetWidth*ratio;canvas.height=canvas.offsetHeight*ratio;canvas.getContext('2d').scale(ratio,ratio);};resize();window.addEventListener('resize',resize);const pad=new SignaturePad(canvas,{backgroundColor:'rgb(255,255,255)'});const input=document.getElementById(inputId);const push=()=>{input.value=pad.isEmpty()?'':pad.toDataURL();};canvas.addEventListener('mouseup',push);canvas.addEventListener('touchend',push);canvas.addEventListener('pointerup',push);const btn=document.getElementById(clearId);if(btn)btn.addEventListener('click',()=>{pad.clear();input.value='';});}
</script><script>
let idx=0;const c=document.getElementById('collabs');
function add(){c.insertAdjacentHTML('beforeend',`<div class="card"><h3>Collaborator #${idx+1}</h3><div class="row"><div><label>Legal name</label><input name="legalName" required></div><div><label>Role</label><input name="role" required></div></div><div class="row"><div><label>Address</label><input name="address" required></div><div><label>Phone</label><input name="phone" required></div></div><div class="row"><div><label>Email</label><input type="email" name="email" required></div><div><label>PRO</label><input name="pro" required></div></div><div class="row"><div><label>IPI #</label><input name="ipi" required></div><div><label>Publisher name</label><input name="publisherName" required></div></div><div><label>Publisher IPI #</label><input name="publisherIpi" required></div><h4>Signature</h4><canvas id="s${idx}" class="sig"></canvas><input type="hidden" id="sd${idx}" name="signatureData"><button type="button" id="cl${idx}">Clear signature</button></div>`);wirePad(`s${idx}`,`sd${idx}`,`cl${idx}`);idx++;}
add();document.getElementById('add').addEventListener('click',add);wirePad('companySig','companySigData','clearCompany');</script></body></html>