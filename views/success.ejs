<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Submitted</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wrap">
    <h1><%= title %></h1>
    <div class="card">
      <p>Submission saved successfully.</p>
      <p><b>ID:</b> <%= id %></p>
      <% if (songTitle) { %>
        <p><b>Song:</b> <%= songTitle %> <% if (version) { %>(v<%= version %>)<% } %></p>
      <% } %>

      <% if (emailResult && emailResult.ok) { %>
        <p style="color:#9be49b;"><b>Email status:</b> Sent successfully.</p>
      <% } else if (emailResult && emailResult.reason === 'smtp_not_configured') { %>
        <p style="color:#ffd48a;"><b>Email status:</b> SMTP is not configured. Set SMTP_USER + SMTP_PASS in .env to send copies automatically.</p>
      <% } else if (emailResult && emailResult.reason && emailResult.reason !== 'not_attempted') { %>
        <p style="color:#ffd48a;"><b>Email status:</b> Attempted but failed (<%= emailResult.reason %>).</p>
      <% } else { %>
        <p>Email notifications were attempted if SMTP is configured.</p>
      <% } %>

      <% if (type === 'split-sheet') { %>
        <p><a href="/split-sheet/pdf/<%= id %>">Download PDF summary</a></p>
      <% } %>
    </div>
    <p><a href="/">Back to home</a></p>
  </div>
</body>
</html>
