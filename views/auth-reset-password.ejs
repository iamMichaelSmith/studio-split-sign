<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Choose new password | SplitSheet Studio</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wrap auth-wrap">
    <div class="auth-card card">
      <h1>Choose a new password</h1>
      <% if (success) { %>
        <div class="card">
          Password updated. Use the new password in the plugin or hosted app account flows.
        </div>
      <% } else { %>
        <p class="small">Set a new password for your SplitSheet Studio account.</p>
        <% if (error) { %>
          <div class="card legal-note"><%= error %></div>
        <% } %>
        <form method="post" action="/reset-password">
          <input type="hidden" name="token" value="<%= token %>">
          <label>New Password</label>
          <input type="password" name="password" placeholder="At least 8 characters" required>
          <button type="submit">Update password</button>
        </form>
      <% } %>
      <p class="small auth-links">
        <a href="/forgot-password">Request another reset link</a>
        <a href="mailto:<%= supportEmail %>">Support</a>
        <a href="<%= baseUrl %>">Back to app</a>
      </p>
    </div>
  </div>
</body>
</html>
