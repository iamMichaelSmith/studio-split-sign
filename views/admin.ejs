<!doctype html><html><head><meta charset="utf-8"><title>Admin</title><link rel="stylesheet" href="/style.css"></head><body><div class="wrap"><h1>Submitted Documents</h1><div class="card"><% if(!docs.length){ %><p>No submissions yet.</p><% } %><% docs.forEach(d=>{ %><div style="border-bottom:1px solid #2a3345;padding:10px 0"><span class="pill"><%= d.type %></span> <b><%= d.id %></b> <span class="small"><%= d.createdAt %></span> - <a href="/admin/doc/<%= d.id %>" target="_blank">view json</a> <% if (d.type === 'split-sheet') { %> - <a href="/split-sheet/pdf/<%= d.id %>" target="_blank">download pdf</a><% } %></div><% }) %></div></div></body></html>