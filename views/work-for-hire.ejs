<!doctype html><html><head><meta charset="utf-8"><title>Work for Hire</title><link rel="stylesheet" href="/style.css"></head><body><div class="wrap"><h1>Work for Hire Agreement</h1><div class="card"><p>All deliverables are specially commissioned works made for hire for Blak Marigold Pro LLC. Rights transfer to Company under agreed payment terms. Contractor may not publicly release deliverables without written approval.</p></div><form method="post" action="/work-for-hire"><div class="card"><div class="row"><div><label>Project title</label><input name="projectTitle" required></div><div><label>Agreed fee (USD)</label><input name="fee" required></div></div><div class="row"><div><label>Contractor legal name</label><input name="contractorName" required></div><div><label>Contractor email</label><input type="email" name="contractorEmail" required></div></div><div class="row"><div><label>Contractor phone</label><input name="contractorPhone" required></div><div><label>Signed date</label><input type="date" name="signedDate" required></div></div><label>Company rep name</label><input name="companyRepName" required><h4>Contractor Signature</h4><canvas id="conSig" class="sig"></canvas><input type="hidden" id="conSigData" name="contractorSignature"><button type="button" id="clearCon">Clear contractor signature</button><h4>Company Signature</h4><canvas id="coSig" class="sig"></canvas><input type="hidden" id="coSigData" name="companyRepSignature"><button type="button" id="clearCo">Clear company signature</button></div><button type="submit">Submit agreement</button></form><p><a href="/">Back</a></p></div><script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
<script>
function wirePad(canvasId,inputId,clearId){const canvas=document.getElementById(canvasId);if(!canvas)return;const resize=()=>{const ratio=Math.max(window.devicePixelRatio||1,1);canvas.width=canvas.offsetWidth*ratio;canvas.height=canvas.offsetHeight*ratio;canvas.getContext('2d').scale(ratio,ratio);};resize();window.addEventListener('resize',resize);const pad=new SignaturePad(canvas,{backgroundColor:'rgb(255,255,255)'});const input=document.getElementById(inputId);const push=()=>{input.value=pad.isEmpty()?'':pad.toDataURL();};canvas.addEventListener('mouseup',push);canvas.addEventListener('touchend',push);const btn=document.getElementById(clearId);if(btn)btn.addEventListener('click',()=>{pad.clear();input.value='';});}
</script><script>wirePad('conSig','conSigData','clearCon');wirePad('coSig','coSigData','clearCo');</script></body></html>