<!doctype html><html><head><meta charset="utf-8"><title>Sign Split Sheet</title><link rel="stylesheet" href="/style.css"></head><body><div class="wrap"><h1>Split Sheet Signature</h1><div class="card"><p><b>Song:</b> <%= doc.payload.songTitle %></p><p><b>Contributor:</b> <%= signer.legalName %> (<%= signer.role %>)</p><p><b>Writer:</b> <%= signer.writerShare %>% | <b>Publisher:</b> <%= signer.publisherShare %>%</p></div>

<% if (error) { %><div class="card"><b><%= error %></b></div><% } %>
<% if (success) { %><div class="card"><b><%= success %></b></div><% } %>

<form method="post" class="card">
  <label>Typed signature name</label>
  <input name="typedSignatureName" value="<%= signer.typedSignatureName || '' %>" required>

  <h4>Draw signature</h4>
  <div class="sig-wrap"><canvas id="sig" class="sig"></canvas><span class="sig-hint" id="sig-hint">sign</span></div>
  <input type="hidden" id="signatureData" name="signatureData" value="<%= signer.signatureData || '' %>">
  <button type="button" id="clearSig">Clear signature</button>

  <button type="submit">Sign now</button>
</form>

<p><a href="/">Back to home</a></p></div>
<script src="/vendor/signature_pad/signature_pad.umd.min.js"></script>
<script>
const canvas=document.getElementById('sig');
const input=document.getElementById('signatureData');
const hint=document.getElementById('sig-hint');
if (typeof SignaturePad === 'undefined') {
  hint.textContent = 'signature tool failed to load - refresh page';
} else {
  const resize=()=>{const ratio=Math.max(window.devicePixelRatio||1,1);canvas.width=canvas.offsetWidth*ratio;canvas.height=canvas.offsetHeight*ratio;canvas.getContext('2d').scale(ratio,ratio);};
  resize();window.addEventListener('resize',resize);
  const pad=new SignaturePad(canvas,{backgroundColor:'rgb(255,255,255)'});
  if(input.value && input.value.startsWith('data:image/')){ try{ pad.fromDataURL(input.value);}catch{} }
  const sync=()=>{const has=!pad.isEmpty(); input.value=has?pad.toDataURL():''; hint.style.display=has?'none':'block';};
  canvas.addEventListener('mouseup',sync);canvas.addEventListener('touchend',sync);canvas.addEventListener('pointerup',sync);
  document.getElementById('clearSig').addEventListener('click',()=>{pad.clear();sync();});
  sync();
}
</script></body></html>
