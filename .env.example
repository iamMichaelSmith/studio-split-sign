PORT=5050
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:5050

# Change these before real use
ADMIN_USER=change-me
ADMIN_PASS=change-me-strong-password
SESSION_SECRET=change-me-long-random-string
COOKIE_SECURE=false

# SMTP path still works if you prefer it, but SES direct send is also supported.
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SES direct-send path
SES_REGION=us-east-1
FROM_EMAIL=no-reply@blakmarigold.com
REPLY_TO_EMAIL=Blakmarigold@gmail.com
NOTIFY_EMAIL=Blakmarigold@gmail.com
