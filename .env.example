PORT=5050
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:5050
DB_PROVIDER=sqlite
DB_PATH=./data/app.db
DATABASE_URL=
PDF_STORAGE=local
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=final-pdfs

# Change these before real use
ADMIN_USER=change-me
ADMIN_PASS=change-me-strong-password
SESSION_SECRET=change-me-long-random-string
SESSION_STORE=memory
REDIS_URL=
REDIS_PREFIX=splitsheet:sess:
COOKIE_SECURE=false
TRUST_PROXY=false
API_TOKEN_SECRET=change-me-separate-api-token-secret
API_ACCESS_TOKEN_TTL_MINUTES=15
API_REFRESH_TOKEN_TTL_DAYS=30
ALLOW_PUBLIC_REGISTRATION=false
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_DISPLAY_NAME=SplitSheet Studio Owner

# SMTP path still works if you prefer it, but SES direct send is also supported.
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SES direct-send path
SES_REGION=us-east-1
FROM_EMAIL=no-reply@blakmarigold.com
REPLY_TO_EMAIL=Blakmarigold@gmail.com
NOTIFY_EMAIL=Blakmarigold@gmail.com
